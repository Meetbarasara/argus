GOOGLE_API_KEY=            # https://aistudio.google.com (free, no card)
GROQ_API_KEY=              # https://console.groq.com (free, no card)
ACTUATOR_TOKEN=dev-actuator-token
LLM_MODE=live              # live | record | replay | fake
# On a rate-limit/quota error, retry the call down this comma-separated CHAIN of
# provider:model fallbacks, in order. Each free model carries its own budget, so exhausting
# one rolls onto the next. Empty = off.
# e.g. LLM_FALLBACK=groq:llama-3.3-70b-versatile,groq:llama-3.1-8b-instant
LLM_FALLBACK=
AUTO_APPROVE=off           # off | policy_sim   (policy_sim only for eval runs)
MEMORY_ENABLED=true
DATABASE_URL=postgresql+psycopg://argus:argus@localhost:5433/argus
PLATFORM_API_URL=http://localhost:8080
OTEL_EXPORT_JAEGER=false
